<Window x:Class="CbrConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Convertisseur CBR / CBZ / PDF"
    Icon="pack://application:,,,/Resources/Icons/app.ico"
    Width="500" Height="560"
    MinWidth="460" MinHeight="520"
        WindowStartupLocation="CenterScreen"
    Background="#EEF2F7"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13">

    <Window.Resources>

        <!-- Couleurs -->
        <SolidColorBrush x:Key="AccentBrush"       Color="#0078D4"/>
        <SolidColorBrush x:Key="AccentHoverBrush"  Color="#006CBD"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#005A9E"/>
        <SolidColorBrush x:Key="SuccessBrush"      Color="#107C10"/>
        <SolidColorBrush x:Key="SurfaceBrush"      Color="#F9F9F9"/>
        <SolidColorBrush x:Key="CardBrush"         Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrush"       Color="#D1D1D1"/>
        <SolidColorBrush x:Key="BorderHoverBrush"  Color="#0078D4"/>
        <SolidColorBrush x:Key="TextPrimaryBrush"  Color="#1A1A1A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#5A5A5A"/>
        <SolidColorBrush x:Key="TextMutedBrush"    Color="#9A9A9A"/>
        <SolidColorBrush x:Key="DividerBrush"      Color="#E0E0E0"/>
        <SolidColorBrush x:Key="HoverBrush"        Color="#F5F5F5"/>
        <SolidColorBrush x:Key="TitleBarBrush"     Color="#F3F3F3"/>
        <!-- Style : Bouton primaire -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background"   Value="#0078D4"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"       Value="32"/>
            <Setter Property="Padding"      Value="16,0"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="Medium"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#006CBD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#C8C8C8"/>
                                <Setter Property="Foreground" Value="#7A7A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style : Bouton secondaire -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="Foreground"      Value="#1A1A1A"/>
            <Setter Property="BorderBrush"     Value="#D1D1D1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"   Value="#F5F5F5"/>
                                <Setter TargetName="bd" Property="BorderBrush"  Value="#BBBBBB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EBEBEB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style : CheckBox Fluent -->
        <Style x:Key="FluentCheckBox" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="row"
                                Background="White"
                            Padding="12,8"
                                Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="box"
                                        Width="18" Height="18"
                                        CornerRadius="3"
                                        BorderBrush="#8A8A8A"
                                        BorderThickness="1.5"
                                        Background="White"
                                        Margin="0,0,10,0"
                                        VerticalAlignment="Top">
                                    <Path x:Name="chk"
                                          Data="M2,5 L6,9 L13,2"
                                          Stroke="White"
                                          StrokeThickness="1.5"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Visibility="Collapsed"
                                          Stretch="None"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Border>
                                <ContentPresenter Grid.Column="1"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="box" Property="Background"   Value="#0078D4"/>
                                <Setter TargetName="box" Property="BorderBrush"  Value="#0078D4"/>
                                <Setter TargetName="chk" Property="Visibility"   Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="row" Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style : ProgressBar Fluent -->
        <Style x:Key="FluentProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="4"/>
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Height="{TemplateBinding Height}">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="2"
                                        HorizontalAlignment="Left"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style : TextBox champ fichier -->
        <Style x:Key="FileTextBox" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="#1A1A1A"/>
            <Setter Property="IsReadOnly"      Value="True"/>
            <Setter Property="Padding"         Value="8,0"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>      <!-- Contenu -->
            <RowDefinition Height="Auto"/>   <!-- StatusBar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════ CONTENU PRINCIPAL ═══════════════ -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                  Background="Transparent">
            <Border Margin="14,10,14,12"
                Padding="14,12"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="#D7DDE7"
                Background="#FCFCFD">
            <StackPanel>

                <!-- ── Section Fichiers ── -->
                <StackPanel Margin="0,0,0,12">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Fichiers"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#1A1A1A"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Separator Grid.Column="1"
                                   Background="#E0E0E0"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Champ Source -->
                    <TextBlock Text="Source"
                               FontSize="11" Foreground="#7A7A7A"
                               Margin="0,0,0,3"/>
                    <Border x:Name="BorderSource"
                            Background="White"
                            BorderBrush="#D1D1D1"
                            BorderThickness="1"
                            CornerRadius="4"
                            Margin="0,0,0,6"
                            Cursor="Hand"
                            MouseLeftButtonUp="BorderSource_MouseLeftButtonUp">
                        <Grid Height="32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    BorderBrush="#E8E8E8"
                                    BorderThickness="0,0,1,0">
                                <Path Data="M2,9 L8,9 M2,9 L2,13 L14,13 L14,5 L8,5 L6,3 L2,3 Z"
                                      Stroke="#0078D4" StrokeThickness="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Stretch="None"/>
                            </Border>
                            <TextBox x:Name="TxtSource"
                                     Grid.Column="1"
                                     Style="{StaticResource FileTextBox}"
                                     Text=""
                                     ToolTip="Chemin du fichier ou dossier source"
                                     IsHitTestVisible="False"/>
                            <Button Grid.Column="2"
                                    x:Name="BtnBrowseSource"
                                    Click="BtnBrowseSource_Click"
                                    Background="#F3F3F3"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1,0,0,0"
                                    Cursor="Hand"
                                    ToolTip="Parcourir"
                                    IsHitTestVisible="False">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="0,4,4,0">
                                            <Path Data="M6,2 L10,6 L6,10"
                                                  Stroke="#0078D4" StrokeThickness="1.2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Stretch="None"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#E6F0FB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Champ Destination -->
                    <TextBlock Margin="0,0,0,3">
                        <Run Text="Destination" FontSize="11" Foreground="#7A7A7A"/>
                        <Run Text="(optionnel — dossier source par défaut)" FontSize="11" Foreground="#BBBBBB"/>
                    </TextBlock>
                    <Border x:Name="BorderDest"
                            Background="White"
                            BorderBrush="#D1D1D1"
                            BorderThickness="1"
                            CornerRadius="4"
                            Cursor="Hand"
                            MouseLeftButtonUp="BorderDest_MouseLeftButtonUp">
                        <Grid Height="32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="32"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    BorderBrush="#E8E8E8"
                                    BorderThickness="0,0,1,0">
                                <Path Data="M2,9 L8,9 M2,9 L2,13 L14,13 L14,5 L8,5 L6,3 L2,3 Z"
                                      Stroke="#AAAAAA" StrokeThickness="1"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Stretch="None"/>
                            </Border>
                            <TextBox x:Name="TxtDest"
                                     Grid.Column="1"
                                     Style="{StaticResource FileTextBox}"
                                     Foreground="#AAAAAA"
                                     Text=""
                                     ToolTip="Chemin du dossier de destination"
                                     IsHitTestVisible="False"/>
                            <Button Grid.Column="2"
                                    x:Name="BtnBrowseDest"
                                    Click="BtnBrowseDest_Click"
                                    Background="#F3F3F3"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1,0,0,0"
                                    Cursor="Hand"
                                    ToolTip="Parcourir"
                                    IsHitTestVisible="False">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bd"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="0,4,4,0">
                                            <Path Data="M6,2 L10,6 L6,10"
                                                  Stroke="#AAAAAA" StrokeThickness="1.2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Stretch="None"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#F0F0F0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </StackPanel>

                <!-- ── Section Options ── -->
                <StackPanel Margin="0,0,0,12">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Options"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#1A1A1A"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Separator Grid.Column="1"
                                   Background="#E0E0E0"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Border Background="White"
                            BorderBrush="#D1D1D1"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="0">
                        <StackPanel>
                            <CheckBox x:Name="ChkFusion"
                                      IsChecked="True"
                                      Style="{StaticResource FluentCheckBox}">
                                <StackPanel Margin="0,-1,0,0">
                                    <TextBlock Text="Fusionner les images par page"
                                               Foreground="#1A1A1A"/>
                                    <TextBlock Text="Combine les doubles pages en une seule page PDF"
                                               FontSize="11"
                                               Foreground="#7A7A7A"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </CheckBox>
                            <Separator Background="#E8E8E8"/>
                            <CheckBox x:Name="ChkCompress"
                                      Style="{StaticResource FluentCheckBox}">
                                <StackPanel Margin="0,-1,0,0">
                                    <TextBlock Text="Compresser les images"
                                               Foreground="#1A1A1A"/>
                                    <TextBlock Text="Réduit la taille du fichier de sortie"
                                               FontSize="11"
                                               Foreground="#7A7A7A"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── Section Progression ── -->
                <StackPanel Margin="0,0,0,12">
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Progression"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="#1A1A1A"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Separator Grid.Column="1"
                                   Background="#E0E0E0"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Barre Fichier en cours -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Fichier en cours"
                                   FontSize="12" Foreground="#5A5A5A"/>
                        <TextBlock x:Name="TxtProgressFile"
                                   Grid.Column="1"
                                   Text="—"
                                   FontSize="12"
                                   Foreground="#0078D4"
                                   FontWeight="Medium"/>
                    </Grid>
                    <ProgressBar x:Name="ProgressFile"
                                 Style="{StaticResource FluentProgress}"
                                 Value="0" Maximum="100"
                                 Margin="0,0,0,8"/>

                    <!-- Barre Total -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Total"
                                   FontSize="12" Foreground="#5A5A5A"/>
                        <TextBlock x:Name="TxtProgressTotal"
                                   Grid.Column="1"
                                   Text="—"
                                   FontSize="12"
                                   Foreground="#107C10"
                                   FontWeight="Medium"/>
                    </Grid>
                    <ProgressBar x:Name="ProgressTotal"
                                 Style="{StaticResource FluentProgress}"
                                 Foreground="#107C10"
                                 Value="0" Maximum="100"/>
                </StackPanel>

                <!-- ── Boutons d'action ── -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,4,0,0">
                    <Button x:Name="BtnReset"
                            Content="Réinitialiser"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnReset_Click"
                            Margin="0,0,8,0"
                            Width="120"/>
                    <Button x:Name="BtnStart"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnStart_Click"
                            Width="160">
                        <StackPanel Orientation="Horizontal">
                            <Path x:Name="IconStart"
                                  Data="M3,2 L11,6.5 L3,11 Z"
                                  Fill="White"
                                  Stretch="None"
                                  VerticalAlignment="Center"
                                  Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtBtnStart"
                                       Text="Démarrer"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- ═══════════════ BARRE DE STATUT ═══════════════ -->
        <StatusBar Grid.Row="1"
                   Background="#F3F3F3"
                   BorderBrush="#E0E0E0"
                   BorderThickness="0,1,0,0"
               Padding="10,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot"
                             Width="7" Height="7"
                             Fill="#107C10"
                             Margin="0,0,7,0"
                             VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtStatus"
                               Text="Prêt"
                               FontSize="11"
                               Foreground="#7A7A7A"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
